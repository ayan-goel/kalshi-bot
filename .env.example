# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/kalshi_bot

# ── Demo credentials ──
KALSHI_API_KEY=your_demo_api_key
KALSHI_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
...your demo private key...
-----END RSA PRIVATE KEY-----"

# ── Production credentials ──
KALSHI_PROD_API_KEY=your_prod_api_key
KALSHI_PROD_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
...your production private key...
-----END RSA PRIVATE KEY-----"

# API authentication — set to a random string, must match NEXT_PUBLIC_BOT_API_SECRET on the dashboard
# If not set, the API is open (fine for local dev, dangerous in production)
BOT_API_SECRET=change-me-to-a-strong-random-string

# Bot settings
TRADING_ENABLED=false
RUST_LOG=info,kalshi_bot=debug
# In-memory raw log ring buffer size (for /api/raw-logs)
RAW_LOG_BUFFER_CAP=10000
